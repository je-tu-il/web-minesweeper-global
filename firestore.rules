rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Profils utilisateurs
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email == 'jules.eymond0509@gmail.com' ||
        (resource != null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friends']))
      );
    }

    // Rooms de jeu
    match /rooms/{roomId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Leaderboard
    match /leaderboard/{docId} {
      allow read: if true; // Tout le monde peut voir le leaderboard
      allow write: if request.auth != null;
    }

    // Config admin (bannis etc.)
    match /config/{docId} {
      allow read: if request.auth != null;
      // write réservé à l'admin via console
    }
  }
}
