rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth != null;
      // Autoriser l'utilisateur à modifier son propre profil
      // OU autoriser n'importe qui à uniquement s'ajouter/se retirer de la liste "friends" d'un autre
      allow write: if request.auth != null && (
        request.auth.uid == uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friends'])
      );
    }

    match /rooms/{roomId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      // Permettre la suppression d'une room
      allow delete: if request.auth != null;
    }

    match /config/{docId} {
      allow read: if request.auth != null;
    }
  }
}
